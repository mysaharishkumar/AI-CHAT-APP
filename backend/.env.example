MONGODB_URI=your_mongodb_connection_string
DATABASE_NAME=your_database_name
GEMINI_API_KEY=your_gemini_api_key

# Gmail address used to send OTP emails (also the "From" name/address either way)
EMAIL_ADDRESS=your_gmail_address
# Must be a Gmail App Password (not your normal password) — needed if you're
# using the Nodemailer microservice or the direct Gmail SMTP fallback below.
# Create one at: https://myaccount.google.com/apppasswords
EMAIL_PASSWORD=your_gmail_app_password

# OPTION 1 (what you're using): Nodemailer microservice — see /email-service.
# Run that service separately, then point this backend at it.
EMAIL_SERVICE_URL=http://127.0.0.1:4000
# Must match EMAIL_SERVICE_API_KEY in email-service/.env
EMAIL_SERVICE_API_KEY=choose_a_long_random_secret

# OPTION 2 (alternative): Brevo HTTPS API — used only if EMAIL_SERVICE_URL
# above is blank. Sign up free at https://www.brevo.com (300 emails/day free).
BREVO_API_KEY=your_brevo_api_key
# Must exactly match an email verified under Brevo's
# Senders, Domains & IPs page — sends from an unverified
# address are silently rejected. If left blank, falls back
# to EMAIL_ADDRESS above.
BREVO_SENDER_EMAIL=your_verified_brevo_sender_email

# If neither of the above is set, the app falls back to raw Gmail SMTP
# using EMAIL_ADDRESS / EMAIL_PASSWORD above.

# Comma-separated list of frontend origins allowed to call this API.
# Include your deployed frontend URL here once you know it.
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://your-frontend.onrender.com

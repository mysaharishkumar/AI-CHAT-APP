# Same Gmail account/App Password you'd use with Nodemailer directly.
# Create an App Password at: https://myaccount.google.com/apppasswords
EMAIL_ADDRESS=your_gmail_address
EMAIL_PASSWORD=your_gmail_app_password

# Any long random string. Must match EMAIL_SERVICE_API_KEY in backend/.env.
EMAIL_SERVICE_API_KEY=choose_a_long_random_secret

PORT=4000
